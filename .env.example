DATABASE_URL="postgresql://YOUR_USER@localhost:5432/friogestion?schema=public"
# Usar DIRECT_URL solo si luego separas URL de runtime (pool) y URL directa para migraciones.
DIRECT_URL="postgresql://YOUR_USER@localhost:5432/friogestion?schema=public"
JWT_SECRET="change-me"
AFIP_ENV="testing"

# Requerida para cifrar secretos ARCA guardados en DB (base64 de 32 bytes).
ARCA_SECRETS_KEY="base64-32-bytes"

# Token AFIP SDK global (opcional, alias legacy abajo).
AFIP_SDK_ACCESS_TOKEN="change-me"

# Aliases legacy del token (opcional, usar solo uno si queres compatibilidad).
# ACCESS_TOKEN="change-me"
# AFIP_ACCESS_TOKEN="change-me"

# Fallback global opcional (si no usas certificados/identidad por organizacion en DB).
# AFIP_CUIT="20123456789"
# AFIP_CERT_BASE64="base64-pem"
# AFIP_KEY_BASE64="base64-pem"

# Legacy fallback de clave de cifrado (opcional si no usas ARCA_SECRETS_KEY).
AFIP_SECRET_KEY="base64-32-bytes"
