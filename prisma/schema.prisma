model DeliveryNote {
  id                    String             @id @default(cuid())
  organizationId        String
  type                  DeliveryNoteType
  pointOfSale           Int
  number                Int?
  status                DeliveryNoteStatus @default(DRAFT)
  issuedAt              DateTime?
  deliveredAt           DateTime?
  customerId            String?
  supplierId            String?
  saleId                String?
  purchaseInvoiceId     String?
  observations          String?
  digitalRepresentation Boolean            @default(true)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  organization    Organization       @relation(fields: [organizationId], references: [id])
  customer        Customer?          @relation(fields: [customerId], references: [id])
  supplier        Supplier?          @relation(fields: [supplierId], references: [id])
  sale            Sale?              @relation(fields: [saleId], references: [id])
  purchaseInvoice PurchaseInvoice?   @relation(fields: [purchaseInvoiceId], references: [id])
  items           DeliveryNoteItem[]

  @@unique([organizationId, type, pointOfSale, number])
  @@index([organizationId])
  @@index([status])
  @@index([customerId])
  @@index([supplierId])
  @@index([saleId])
  @@index([purchaseInvoiceId])
}

model DeliveryNoteItem {
