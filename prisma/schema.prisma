  @@index([accountId])
}

model CurrentAccountEntry {
  id                String                 @id @default(cuid())
  organizationId    String
  counterpartyType  LedgerCounterpartyType
  customerId        String?
  supplierId        String?
  direction         LedgerDirection
  sourceType        LedgerSourceType
  saleId            String?
  receiptId         String?
