  qty            Decimal  @db.Decimal(12, 3)
  unit           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  deliveryNote DeliveryNote @relation(fields: [deliveryNoteId], references: [id])
  product      Product?     @relation(fields: [productId], references: [id])

  @@index([deliveryNoteId])
  @@index([productId])
}

model OrganizationCounter {
  id             String   @id @default(cuid())
  organizationId String
  key            String
  nextValue      Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, key])
  @@index([organizationId])
}

model StorefrontChannel {
  id                           String   @id @default(cuid())
  organizationId               String
  code                         String   @default("default")
  name                         String
  isActive                     Boolean  @default(true)
  storeName                    String
  supportEmail                 String?
  supportPhone                 String?
  pickupAddress                String?
  currencyCode                 String   @default("ARS")
  defaultPriceListId           String?
  allowsCustomerAccounts       Boolean  @default(true)
  customerAccountsMode         String   @default("prepared")
  defaultPaymentMethod         String   @default("mercadopago_checkout_api")
  globalPriceAdjustmentPercent Decimal  @default(0) @db.Decimal(8, 4)
  normalShippingAmount         Decimal  @default(0) @db.Decimal(12, 2)
  reserveTtlMinutes            Int      @default(30)
  manualBillingByDefault       Boolean  @default(true)
  productCategories            Json?
  mercadoPagoFeeRegion         String?
  mercadoPagoFeeRules          Json?
  mercadoPagoDefaultFeeDays    Int?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  organization       Organization                  @relation(fields: [organizationId], references: [id])
  defaultPriceList   PriceList?                    @relation(fields: [defaultPriceListId], references: [id])
  apiKeys            StorefrontApiKey[]
  paymentAdjustments StorefrontPaymentAdjustment[]
  publications       StorefrontPublication[]
  orders             StorefrontOrder[]
  reservations       StorefrontStockReservation[]
  paymentEvents      StorefrontPaymentEvent[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([defaultPriceListId])
}

model StorefrontApiKey {
  id             String    @id @default(cuid())
  organizationId String
  channelId      String
  label          String
  keyHash        String    @unique
  keyPrefix      String
  isActive       Boolean   @default(true)
  lastUsedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id])
  channel      StorefrontChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([channelId])
  @@index([isActive])
}

model StorefrontPaymentAdjustment {
  id             String   @id @default(cuid())
  organizationId String
  channelId      String
  paymentMethod  String
  percent        Decimal  @default(0) @db.Decimal(8, 4)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id])
  channel      StorefrontChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, paymentMethod])
  @@index([organizationId])
  @@index([channelId])
  @@index([isActive])
}

model StorefrontPublication {
  id                           String                      @id @default(cuid())
  organizationId               String
  channelId                    String
  productId                    String
  slug                         String
  publicationStatus            StorefrontPublicationStatus @default(PAUSED)
  publicName                   String
  shortDescription             String
  longDescription              String
  category                     String                      @default("General")
  featured                     Boolean                     @default(false)
  shippingType                 StorefrontShippingType      @default(NORMAL)
  normalShippingOverrideAmount Decimal?                    @db.Decimal(12, 2)
  hasGas                       Boolean                     @default(false)
  hasPressure                  Boolean                     @default(false)
  isFlammable                  Boolean                     @default(false)
  hasSpecialLogistics          Boolean                     @default(false)
  stockMode                    StorefrontStockMode         @default(STRICT)
  webStockAvailable            Int                         @default(0)
  webStockReserved             Int                         @default(0)
  pricingMode                  StorefrontPricingMode       @default(AUTO)
  fixedFinalPrice              Decimal?                    @db.Decimal(12, 2)
  priceAdjustmentPercent       Decimal                     @default(0) @db.Decimal(8, 4)
  mercadoPagoFeeDays           Int?
  billingMode                  StorefrontBillingMode       @default(DEFAULT)
  images                       Json?
  technicalSheet               Json?
  createdAt                    DateTime                    @default(now())
  updatedAt                    DateTime                    @updatedAt

  organization Organization                 @relation(fields: [organizationId], references: [id])
  channel      StorefrontChannel            @relation(fields: [channelId], references: [id], onDelete: Cascade)
  product      Product                      @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems   StorefrontOrderItem[]
  reservations StorefrontStockReservation[]

  @@unique([channelId, productId])
  @@unique([channelId, slug])
  @@index([organizationId])
  @@index([channelId])
  @@index([productId])
  @@index([publicationStatus])
  @@index([channelId, publicationStatus, featured, publicName], map: "storefront_publication_channel_status_featured_name_idx")
  @@index([channelId, category], map: "storefront_publication_channel_category_idx")
  @@index([channelId, shippingType], map: "storefront_publication_channel_shipping_type_idx")
}

model StorefrontOrder {
  id                      String                        @id @default(cuid())
  organizationId          String
  channelId               String
  saleId                  String?                       @unique
  displayNumber           String?
  status                  StorefrontOrderStatus         @default(PENDING_PAYMENT)
  paymentStatus           StorefrontOrderPaymentStatus  @default(PENDING)
  currencyCode            String                        @default("ARS")
  subtotal                Decimal                       @db.Decimal(12, 2)
  shippingTotal           Decimal                       @default(0) @db.Decimal(12, 2)
  total                   Decimal                       @db.Decimal(12, 2)
  deliveryMethod          StorefrontOrderDeliveryMethod
  deliveryAddress         Json?
  paymentMethod           String
  manualBillingRequired   Boolean                       @default(true)
  customerDisplayName     String
  customerEmail           String
  customerPhone           String?
  customerTaxId           String?
  customerFiscalCondition String?
  paymentReference        String?
  externalReference       String?
  expiresAt               DateTime?
  approvedAt              DateTime?
  rejectedAt              DateTime?
  cancelledAt             DateTime?
  rawRequest              Json?
  createdAt               DateTime                      @default(now())
  updatedAt               DateTime                      @updatedAt

  organization  Organization                 @relation(fields: [organizationId], references: [id])
  channel       StorefrontChannel            @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sale          Sale?                        @relation(fields: [saleId], references: [id])
  items         StorefrontOrderItem[]
  reservations  StorefrontStockReservation[]
  paymentEvents StorefrontPaymentEvent[]

  @@index([organizationId])
  @@index([channelId])
  @@index([status])
  @@index([paymentStatus])
  @@index([displayNumber])
  @@index([createdAt])
  @@index([channelId, displayNumber], map: "storefront_order_channel_display_number_idx")
  @@index([channelId, paymentReference], map: "storefront_order_channel_payment_ref_idx")
  @@index([channelId, externalReference], map: "storefront_order_channel_external_ref_idx")
}

model StorefrontOrderItem {
  id                     String                 @id @default(cuid())
  organizationId         String
  orderId                String
  publicationId          String?
  productId              String
  sku                    String?
  publicName             String
  quantity               Int
  unitPriceFinal         Decimal                @db.Decimal(12, 2)
  lineTotal              Decimal                @db.Decimal(12, 2)
  stockMode              StorefrontStockMode
  shippingType           StorefrontShippingType
  pricingMode            StorefrontPricingMode
  fixedFinalPrice        Decimal?               @db.Decimal(12, 2)
  basePrice              Decimal?               @db.Decimal(12, 2)
  adjustmentPercentTotal Decimal                @default(0) @db.Decimal(8, 4)
  manualBilling          Boolean                @default(true)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  organization Organization           @relation(fields: [organizationId], references: [id])
  order        StorefrontOrder        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  publication  StorefrontPublication? @relation(fields: [publicationId], references: [id], onDelete: SetNull)
  product      Product                @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([orderId])
  @@index([publicationId])
  @@index([productId])
}

model StorefrontStockReservation {
  id             String                      @id @default(cuid())
  organizationId String
  channelId      String
  orderId        String
  publicationId  String
  productId      String
  quantity       Int
  status         StorefrontReservationStatus @default(RESERVED)
  expiresAt      DateTime
  releasedAt     DateTime?
  releaseReason  String?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id])
  channel      StorefrontChannel     @relation(fields: [channelId], references: [id], onDelete: Cascade)
  order        StorefrontOrder       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  publication  StorefrontPublication @relation(fields: [publicationId], references: [id], onDelete: Restrict)
  product      Product               @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([channelId])
  @@index([orderId])
  @@index([publicationId])
  @@index([status])
  @@index([expiresAt])
  @@index([channelId, status, expiresAt], map: "storefront_reservation_channel_status_expires_idx")
}

model StorefrontPaymentEvent {
  id                String                       @id @default(cuid())
  organizationId    String
  channelId         String
  orderId           String
  provider          StorefrontPaymentProvider    @default(MERCADOPAGO)
  action            StorefrontPaymentEventAction
  eventKey          String
  paymentId         String?
  externalReference String?
  payload           Json?
  processedAt       DateTime?
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id])
  channel      StorefrontChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  order        StorefrontOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([channelId, eventKey])
  @@index([organizationId])
  @@index([channelId])
  @@index([orderId])
  @@index([paymentId])
}
