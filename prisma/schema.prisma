generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  SALES
  CASHIER
  VIEWER
  DEVELOPER
}

enum CustomerType {
  CONSUMER_FINAL
  INSTALLER
  BUSINESS
  PUBLIC_ENTITY
}

enum CustomerFiscalTaxProfile {
  RESPONSABLE_INSCRIPTO
  MONOTRIBUTISTA
  MONOTRIBUTO_SOCIAL
  MONOTRIBUTO_TRABAJADOR_INDEPENDIENTE_PROMOVIDO
  CONSUMIDOR_FINAL
  IVA_SUJETO_EXENTO
  IVA_NO_ALCANZADO
  SUJETO_NO_CATEGORIZADO
  IVA_LIBERADO
}

enum PurchaseStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum SaleStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum BillingStatus {
  NOT_BILLED
  TO_BILL
  BILLED
}

enum SalePaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum PurchasePaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum ExtraChargeType {
  PERCENT
  FIXED
  DISCOUNT_PERCENT
  DISCOUNT_FIXED
  DISCOUNT_TOTAL_PERCENT
  DISCOUNT_TOTAL_FIXED
  CARD_INTEREST_PERCENT
  CARD_INTEREST_FIXED
}

enum SaleChargeType {
  INTEREST
}

enum FiscalConfigStatus {
  PENDING
  CONNECTED
  ERROR
}

enum ArcaJobStatus {
  PENDING
  RUNNING
  WAITING
  REQUIRES_ACTION
  COMPLETED
  ERROR
}

enum FiscalIssueJobStatus {
  PENDING
  RUNNING
  COMPLETED
  ERROR
}

enum ArcaJobStep {
  CREATE_CERT
  AUTH_WS
  DONE
}

enum ArcaJobAction {
  CONNECT
  ROTATE
}

enum StockMovementType {
  IN
  OUT
  ADJUST
}

enum PaymentMethodType {
  CASH
  TRANSFER
  CARD
  CHECK
  OTHER
}

enum FinanceAccountType {
  CASH
  BANK
  VIRTUAL
}

enum SupplierPaymentStatus {
  CONFIRMED
  CANCELLED
}

enum SupplierRetentionType {
  VAT
  INCOME
  IIBB
  OTHER
}

enum PurchaseFiscalLineType {
  IIBB_PERCEPTION
  VAT_PERCEPTION
  INCOME_TAX_PERCEPTION
  MUNICIPAL_PERCEPTION
  INTERNAL_TAX
  OTHER
}

enum SupplierArcaVerificationStatus {
  PENDING
  MATCH
  PARTIAL
  MISMATCH
  NO_ENCONTRADO
  ERROR
}

enum PurchaseArcaValidationStatus {
  PENDING
  AUTHORIZED
  OBSERVED
  REJECTED
  ERROR
}

enum DeliveryNoteType {
  R
  X
}

enum DeliveryNoteStatus {
  DRAFT
  ISSUED
  DELIVERED
  CANCELLED
}

enum ReceiptStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum InstallmentPlanType {
  CARD
  CREDIT
}

enum InstallmentFrequency {
  MONTHLY
}

enum InstallmentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum AccountMovementDirection {
  IN
  OUT
}

enum LedgerCounterpartyType {
  CUSTOMER
  SUPPLIER
}

enum LedgerDirection {
  DEBIT
  CREDIT
}

enum LedgerSourceType {
  SALE
  RECEIPT
  PURCHASE
  SUPPLIER_PAYMENT
  ADJUSTMENT
}

enum StorefrontPublicationStatus {
  PUBLISHED
  PAUSED
}

enum StorefrontStockMode {
  STRICT
  CONSULT
  BACKORDER
  OUT_OF_STOCK
}

enum StorefrontPricingMode {
  AUTO
  FIXED
}

enum StorefrontBillingMode {
  DEFAULT
  MANUAL
  AUTO
}

enum StorefrontShippingType {
  NORMAL
  PICKUP
  OWN_DELIVERY
  QUOTE
  RESTRICTED
}

enum StorefrontOrderStatus {
  PENDING_PAYMENT
  CONFIRMED
  REJECTED
  CANCELLED
  EXPIRED
}

enum StorefrontOrderPaymentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  REFUNDED
}

enum StorefrontOrderDeliveryMethod {
  NORMAL
  PICKUP
  OWN_DELIVERY
  QUOTE
}

enum StorefrontReservationStatus {
  RESERVED
  CONSUMED
  RELEASED
  EXPIRED
}

enum StorefrontPaymentProvider {
  MERCADOPAGO
}

enum StorefrontPaymentEventAction {
  APPROVED
  REJECTED
}

model Organization {
  id                             String    @id @default(cuid())
  name                           String
  legalName                      String?
  taxId                          String?
  address                        String?
  phone                          String?
  email                          String?
  activityStart                  DateTime?
  website                        String?
  socialMedia                    String?
  receiptApprovalRoles           String[]  @default([])
  receiptDoubleCheckRoles        String[]  @default([])
  adjustStockOnQuoteConfirm      Boolean   @default(true)
  defaultDeliveryNotePointOfSale Int       @default(1)
  createdAt                      DateTime  @default(now())
  updatedAt                      DateTime  @updatedAt

  memberships                  Membership[]
  currencies                   FinanceCurrency[]
  exchangeRates                ExchangeRate[]
  accounts                     FinanceAccount[]
  paymentMethods               PaymentMethod[]
  products                     Product[]
  customers                    Customer[]
  suppliers                    Supplier[]
  priceLists                   PriceList[]
  purchases                    PurchaseInvoice[]
  quotes                       Quote[]
  sales                        Sale[]
  saleEvents                   SaleEvent[]
  saleCharges                  SaleCharge[]
  receipts                     Receipt[]
  accountMoves                 AccountMovement[]
  currentAccountEntries        CurrentAccountEntry[]
  supplierPayments             SupplierPayment[]
  cashReconciliations          CashReconciliation[]
  stockMoves                   StockMovement[]
  fiscalInvoices               FiscalInvoice[]
  creditNotes                  FiscalCreditNote[]
  debitNotes                   FiscalDebitNote[]
  installmentPlans             InstallmentPlan[]
  fiscalConfig                 OrganizationFiscalConfig?
  arcaJobs                     ArcaConnectionJob[]
  fiscalIssueJobs              FiscalInvoiceIssueJob[]
  fiscalIssueQueueState        FiscalIssueQueueState?
  counters                     OrganizationCounter[]
  arcaTaxpayerLookupCache      ArcaTaxpayerLookupCache[]
  supplierArcaVerifications    SupplierArcaVerification[]
  purchaseArcaValidations      PurchaseArcaValidation[]
  deliveryNotes                DeliveryNote[]
  storefrontChannels           StorefrontChannel[]
  storefrontApiKeys            StorefrontApiKey[]
  storefrontPaymentAdjustments StorefrontPaymentAdjustment[]
  storefrontPublications       StorefrontPublication[]
  storefrontOrders             StorefrontOrder[]
  storefrontOrderItems         StorefrontOrderItem[]
  storefrontReservations       StorefrontStockReservation[]
  storefrontPaymentEvents      StorefrontPaymentEvent[]
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships                Membership[]
  saleEvents                 SaleEvent[]
  receiptsCreated            Receipt[]                  @relation("ReceiptCreatedBy")
  receiptsConfirmed          Receipt[]                  @relation("ReceiptConfirmedBy")
  accountMovementsVerified   AccountMovement[]          @relation("AccountMovementVerifiedBy")
  supplierPaymentsCancelled  SupplierPayment[]          @relation("SupplierPaymentCancelledBy")
  cashReconciliationsCreated CashReconciliation[]       @relation("CashReconciliationCreatedBy")
  supplierArcaVerifications  SupplierArcaVerification[] @relation("SupplierArcaVerificationActor")
  purchaseArcaValidations    PurchaseArcaValidation[]   @relation("PurchaseArcaValidationActor")
}

model Membership {
  id             String         @id @default(cuid())
  organizationId String
  userId         String
  role           MembershipRole
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model FinanceCurrency {
  id             String   @id @default(cuid())
  organizationId String
  code           String
  name           String
  symbol         String?
  isDefault      Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, code])
  @@index([organizationId])
}

model ExchangeRate {
  id             String   @id @default(cuid())
  organizationId String
  baseCode       String
  quoteCode      String
  rate           Decimal  @db.Decimal(18, 6)
  asOf           DateTime @default(now())
  source         String?

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, asOf])
}

model FinanceAccount {
  id             String             @id @default(cuid())
  organizationId String
  name           String
  type           FinanceAccountType @default(CASH)
  currencyCode   String
  bankName       String?
  accountNumber  String?
  cbu            String?
  alias          String?
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization            Organization             @relation(fields: [organizationId], references: [id])
  movements               AccountMovement[]
  receiptLines            ReceiptLine[]
  supplierPaymentLines    SupplierPaymentLine[]
  cashReconciliationLines CashReconciliationLine[]

  @@index([organizationId])
}

model PaymentMethod {
  id                  String            @id @default(cuid())
  organizationId      String
  name                String
  type                PaymentMethodType @default(OTHER)
  requiresAccount     Boolean           @default(false)
  requiresApproval    Boolean           @default(false)
  requiresDoubleCheck Boolean           @default(false)
  isActive            Boolean           @default(true)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  organization         Organization          @relation(fields: [organizationId], references: [id])
  receiptLines         ReceiptLine[]
  supplierPaymentLines SupplierPaymentLine[]

  @@index([organizationId])
}

model Product {
  id             String   @id @default(cuid())
  organizationId String
  sku            String?
  purchaseCode   String?
  name           String
  brand          String?
  model          String?
  unit           String?
  cost           Decimal? @db.Decimal(12, 2)
  costUsd        Decimal? @db.Decimal(12, 2)
  price          Decimal? @db.Decimal(12, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization           Organization                 @relation(fields: [organizationId], references: [id])
  priceItems             PriceListItem[]
  purchaseItems          PurchaseItem[]
  quoteItems             QuoteItem[]
  saleItems              SaleItem[]
  stockMoves             StockMovement[]
  deliveryNoteItems      DeliveryNoteItem[]
  storefrontPublications StorefrontPublication[]
  storefrontOrderItems   StorefrontOrderItem[]
  storefrontReservations StorefrontStockReservation[]

  @@unique([organizationId, sku])
  @@index([organizationId])
  @@index([organizationId, name], map: "product_org_name_idx")
  @@index([organizationId, brand], map: "product_org_brand_idx")
  @@index([organizationId, purchaseCode], map: "product_org_purchase_code_idx")
}

model Customer {
  id                 String                   @id @default(cuid())
  organizationId     String
  systemKey          String?
  displayName        String
  legalName          String?
  taxId              String?
  email              String?
  phone              String?
  address            String?
  type               CustomerType             @default(CONSUMER_FINAL)
  fiscalTaxProfile   CustomerFiscalTaxProfile @default(CONSUMIDOR_FINAL)
  defaultPriceListId String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  organization          Organization          @relation(fields: [organizationId], references: [id])
  defaultPriceList      PriceList?            @relation(fields: [defaultPriceListId], references: [id])
  quotes                Quote[]
  sales                 Sale[]
  receipts              Receipt[]
  currentAccountEntries CurrentAccountEntry[]
  deliveryNotes         DeliveryNote[]

  @@unique([organizationId, systemKey])
  @@index([organizationId])
}

model Supplier {
  id                        String                         @id @default(cuid())
  organizationId            String
  displayName               String
  legalName                 String?
  taxId                     String?
  email                     String?
  phone                     String?
  address                   String?
  arcaVerificationStatus    SupplierArcaVerificationStatus @default(PENDING)
  arcaVerificationCheckedAt DateTime?
  arcaVerificationMessage   String?
  arcaVerificationSnapshot  Json?
  createdAt                 DateTime                       @default(now())
  updatedAt                 DateTime                       @updatedAt

  organization          Organization               @relation(fields: [organizationId], references: [id])
  purchaseInvoices      PurchaseInvoice[]
  supplierPayments      SupplierPayment[]
  currentAccountEntries CurrentAccountEntry[]
  arcaVerifications     SupplierArcaVerification[]
  deliveryNotes         DeliveryNote[]

  @@index([organizationId])
  @@index([organizationId, arcaVerificationStatus])
}

model PriceList {
  id              String   @id @default(cuid())
  organizationId  String
  name            String
  currencyCode    String
  isDefault       Boolean  @default(false)
  isConsumerFinal Boolean  @default(false)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization                Organization        @relation(fields: [organizationId], references: [id])
  items                       PriceListItem[]
  customers                   Customer[]
  quotes                      Quote[]
  storefrontChannelsAsDefault StorefrontChannel[]

  @@index([organizationId])
  @@index([organizationId, sortOrder])
}

model PriceListItem {
  id          String   @id @default(cuid())
  priceListId String
  productId   String
  price       Decimal? @db.Decimal(12, 2)
  percentage  Decimal? @db.Decimal(12, 4)

  priceList PriceList @relation(fields: [priceListId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@unique([priceListId, productId])
}

model PurchaseInvoice {
  id                      String                       @id @default(cuid())
  organizationId          String
  supplierId              String
  status                  PurchaseStatus
  paymentStatus           PurchasePaymentStatus        @default(UNPAID)
  invoiceNumber           String?
  invoiceDate             DateTime?
  subtotal                Decimal?                     @db.Decimal(12, 2)
  taxes                   Decimal?                     @db.Decimal(12, 2)
  total                   Decimal?                     @db.Decimal(12, 2)
  fiscalVoucherKind       String?
  fiscalVoucherType       Int?
  fiscalPointOfSale       Int?
  fiscalVoucherNumber     Int?
  authorizationMode       String?
  authorizationCode       String?
  currencyCode            String                       @default("ARS")
  netTaxed                Decimal                      @default(0) @db.Decimal(12, 2)
  netNonTaxed             Decimal                      @default(0) @db.Decimal(12, 2)
  exemptAmount            Decimal                      @default(0) @db.Decimal(12, 2)
  vatTotal                Decimal                      @default(0) @db.Decimal(12, 2)
  otherTaxesTotal         Decimal                      @default(0) @db.Decimal(12, 2)
  paidTotal               Decimal                      @default(0) @db.Decimal(12, 2)
  balance                 Decimal                      @default(0) @db.Decimal(12, 2)
  immediatePaymentLabel   String?
  arcaValidationStatus    PurchaseArcaValidationStatus @default(PENDING)
  arcaValidationCheckedAt DateTime?
  arcaValidationMessage   String?
  arcaValidationRequest   Json?
  arcaValidationResponse  Json?
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt

  organization          Organization                @relation(fields: [organizationId], references: [id])
  supplier              Supplier                    @relation(fields: [supplierId], references: [id])
  items                 PurchaseItem[]
  allocations           SupplierPaymentAllocation[]
  currentAccountEntries CurrentAccountEntry[]
  arcaValidations       PurchaseArcaValidation[]
  deliveryNotes         DeliveryNote[]
  fiscalLines           PurchaseFiscalLine[]

  @@index([organizationId])
  @@index([organizationId, arcaValidationStatus])
}

model PurchaseFiscalLine {
  id                String                 @id @default(cuid())
  purchaseInvoiceId String
  type              PurchaseFiscalLineType
  jurisdiction      String?
  baseAmount        Decimal?               @db.Decimal(12, 2)
  rate              Decimal?               @db.Decimal(7, 4)
  amount            Decimal                @db.Decimal(12, 2)
  note              String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)

  @@index([purchaseInvoiceId])
  @@index([type])
}

model PurchaseItem {
  id                String   @id @default(cuid())
  purchaseInvoiceId String
  productId         String
  qty               Decimal  @db.Decimal(12, 3)
  unitCost          Decimal  @db.Decimal(12, 2)
  total             Decimal  @db.Decimal(12, 2)
  taxRate           Decimal? @db.Decimal(5, 2)
  taxAmount         Decimal? @db.Decimal(12, 2)

  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id])
  product         Product         @relation(fields: [productId], references: [id])
  stockMovement   StockMovement?

  @@index([purchaseInvoiceId])
}

model Quote {
  id             String           @id @default(cuid())
  organizationId String
  customerId     String
  priceListId    String?
  status         QuoteStatus
  quoteNumber    String?
  validUntil     DateTime?
  subtotal       Decimal?         @db.Decimal(12, 2)
  taxes          Decimal?         @db.Decimal(12, 2)
  extraType      ExtraChargeType?
  extraValue     Decimal?         @db.Decimal(12, 2)
  extraAmount    Decimal?         @db.Decimal(12, 2)
  total          Decimal?         @db.Decimal(12, 2)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  priceList    PriceList?   @relation(fields: [priceListId], references: [id])
  items        QuoteItem[]
  sale         Sale?        @relation("QuoteSale")

  @@index([organizationId])
  @@index([priceListId])
}

model QuoteItem {
  id        String   @id @default(cuid())
  quoteId   String
  productId String
  qty       Decimal  @db.Decimal(12, 3)
  unitPrice Decimal  @db.Decimal(12, 2)
  total     Decimal  @db.Decimal(12, 2)
  taxRate   Decimal? @db.Decimal(5, 2)
  taxAmount Decimal? @db.Decimal(12, 2)

  quote   Quote   @relation(fields: [quoteId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model Sale {
  id             String            @id @default(cuid())
  organizationId String
  customerId     String
  quoteId        String?           @unique
  status         SaleStatus
  billingStatus  BillingStatus
  paymentStatus  SalePaymentStatus @default(UNPAID)
  saleNumber     String?
  saleDate       DateTime?
  subtotal       Decimal?          @db.Decimal(12, 2)
  taxes          Decimal?          @db.Decimal(12, 2)
  extraType      ExtraChargeType?
  extraValue     Decimal?          @db.Decimal(12, 2)
  extraAmount    Decimal?          @db.Decimal(12, 2)
  total          Decimal?          @db.Decimal(12, 2)
  paidTotal      Decimal           @default(0) @db.Decimal(12, 2)
  balance        Decimal           @default(0) @db.Decimal(12, 2)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization          Organization           @relation(fields: [organizationId], references: [id])
  customer              Customer               @relation(fields: [customerId], references: [id])
  quote                 Quote?                 @relation("QuoteSale", fields: [quoteId], references: [id])
  items                 SaleItem[]
  saleEvents            SaleEvent[]
  saleCharges           SaleCharge[]
  installmentPlan       InstallmentPlan?
  receipts              Receipt[]
  currentAccountEntries CurrentAccountEntry[]
  fiscalInvoice         FiscalInvoice?
  fiscalInvoiceIssueJob FiscalInvoiceIssueJob?
  creditNotes           FiscalCreditNote[]
  debitNotes            FiscalDebitNote[]
  deliveryNotes         DeliveryNote[]
  storefrontOrder       StorefrontOrder?

  @@index([organizationId])
}

model SaleItem {
  id        String   @id @default(cuid())
  saleId    String
  productId String
  qty       Decimal  @db.Decimal(12, 3)
  unitPrice Decimal  @db.Decimal(12, 2)
  total     Decimal  @db.Decimal(12, 2)
  taxRate   Decimal? @db.Decimal(5, 2)
  taxAmount Decimal? @db.Decimal(12, 2)

  sale          Sale           @relation(fields: [saleId], references: [id])
  product       Product        @relation(fields: [productId], references: [id])
  stockMovement StockMovement?

  @@index([saleId])
}

model SaleEvent {
  id             String   @id @default(cuid())
  organizationId String
  saleId         String
  actorUserId    String?
  action         String
  note           String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  sale         Sale         @relation(fields: [saleId], references: [id])
  actor        User?        @relation(fields: [actorUserId], references: [id])

  @@index([organizationId])
  @@index([saleId])
  @@index([actorUserId])
}

model Receipt {
  id                String        @id @default(cuid())
  organizationId    String
  customerId        String
  saleId            String?
  status            ReceiptStatus @default(PENDING)
  createdByUserId   String?
  confirmedByUserId String?
  confirmedAt       DateTime?
  receiptNumber     String?
  receivedAt        DateTime      @default(now())
  total             Decimal       @db.Decimal(12, 2)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  organization          Organization          @relation(fields: [organizationId], references: [id])
  customer              Customer              @relation(fields: [customerId], references: [id])
  sale                  Sale?                 @relation(fields: [saleId], references: [id])
  createdBy             User?                 @relation("ReceiptCreatedBy", fields: [createdByUserId], references: [id])
  confirmedBy           User?                 @relation("ReceiptConfirmedBy", fields: [confirmedByUserId], references: [id])
  lines                 ReceiptLine[]
  installmentPayments   InstallmentPayment[]
  currentAccountEntries CurrentAccountEntry[]

  @@index([organizationId])
  @@index([createdByUserId])
  @@index([confirmedByUserId])
}

model ReceiptLine {
  id              String   @id @default(cuid())
  receiptId       String
  paymentMethodId String
  accountId       String?
  currencyCode    String
  amount          Decimal  @db.Decimal(12, 2)
  amountBase      Decimal  @db.Decimal(12, 2)
  fxRateUsed      Decimal? @db.Decimal(18, 6)

  receipt         Receipt          @relation(fields: [receiptId], references: [id])
  paymentMethod   PaymentMethod    @relation(fields: [paymentMethodId], references: [id])
  account         FinanceAccount?  @relation(fields: [accountId], references: [id])
  accountMovement AccountMovement?

  @@index([receiptId])
}

model SaleCharge {
  id             String         @id @default(cuid())
  organizationId String
  saleId         String
  type           SaleChargeType
  amount         Decimal        @db.Decimal(12, 2)
  note           String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  sale         Sale         @relation(fields: [saleId], references: [id])

  @@index([organizationId])
  @@index([saleId])
}

model InstallmentPlan {
  id                String               @id @default(cuid())
  organizationId    String
  saleId            String               @unique
  type              InstallmentPlanType
  installmentsCount Int
  interestRate      Decimal?             @db.Decimal(5, 2)
  principal         Decimal              @db.Decimal(12, 2)
  interestAmount    Decimal              @db.Decimal(12, 2)
  total             Decimal              @db.Decimal(12, 2)
  startDate         DateTime
  frequency         InstallmentFrequency @default(MONTHLY)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id])
  sale         Sale          @relation(fields: [saleId], references: [id])
  installments Installment[]

  @@index([organizationId])
}

model Installment {
  id         String            @id @default(cuid())
  planId     String
  number     Int
  dueDate    DateTime
  amount     Decimal           @db.Decimal(12, 2)
  paidAmount Decimal           @default(0) @db.Decimal(12, 2)
  status     InstallmentStatus @default(PENDING)
  paidAt     DateTime?

  plan     InstallmentPlan      @relation(fields: [planId], references: [id])
  payments InstallmentPayment[]

  @@index([planId])
}

model InstallmentPayment {
  id            String   @id @default(cuid())
  installmentId String
  receiptId     String
  amount        Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now())

  installment Installment @relation(fields: [installmentId], references: [id])
  receipt     Receipt     @relation(fields: [receiptId], references: [id])

  @@index([installmentId])
  @@index([receiptId])
}

model AccountMovement {
  id                    String                   @id @default(cuid())
  organizationId        String
  accountId             String
  occurredAt            DateTime                 @default(now())
  direction             AccountMovementDirection
  amount                Decimal                  @db.Decimal(12, 2)
  currencyCode          String
  requiresVerification  Boolean                  @default(false)
  verifiedAt            DateTime?
  verifiedByUserId      String?
  note                  String?
  receiptLineId         String?                  @unique
  supplierPaymentLineId String?                  @unique
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  organization        Organization         @relation(fields: [organizationId], references: [id])
  account             FinanceAccount       @relation(fields: [accountId], references: [id])
  receiptLine         ReceiptLine?         @relation(fields: [receiptLineId], references: [id])
