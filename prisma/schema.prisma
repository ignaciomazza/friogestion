  @@index([organizationId])
  @@index([organizationId, counterpartyType])
  @@index([customerId])
  @@index([supplierId])
  @@index([saleId])
  @@index([receiptId])
  @@index([purchaseInvoiceId])
  @@index([supplierPaymentId])
}

model StockMovement {
